<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/backgroundColor">

    <!-- Top Action Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_margin="12dp"
        app:cardBackgroundColor="?attr/cardBackgroundColor"
        app:cardCornerRadius="28dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="8dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back"
                    app:tint="?attr/mainTextColor" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/btnHand"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_hand"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/btnZoom"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/reset_svgrepo_com"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/btnReference"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_reference"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/btnTimelapse"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_timelapse"
                    app:tint="?attr/mainTextColor" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/btnUndo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_undo"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/btnRedo"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_redo"
                    app:tint="?attr/mainTextColor" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/btnLayers"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_layers"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/btnSave"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_save"
                    app:tint="@color/purple_main" />

            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Canvas Area -->
    <alex.kaghktsyan.colora.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <!-- Left Side Tools -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/sideTools"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:cardBackgroundColor="?attr/cardBackgroundColor"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toTopOf="@+id/bottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <ScrollView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp">

                <ImageButton
                    android:id="@+id/toolBrush"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_brush"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/toolEraser"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_eraser"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/toolFill"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_fill"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/toolPicker"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_eyedropper"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/toolShapes"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_shapes"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/toolSymmetry"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_symmetry"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/toolText"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_text"
                    app:tint="?attr/mainTextColor" />

                <ImageButton
                    android:id="@+id/toolSelect"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/chip_selector"
                    android:src="@drawable/ic_rect"
                    app:tint="?attr/mainTextColor" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Shapes Horizontal Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/shapesPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/cardBackgroundColor"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/sideTools"
        app:layout_constraintStart_toEndOf="@id/sideTools"
        app:layout_constraintTop_toTopOf="@id/sideTools">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp">

            <ImageButton
                android:id="@+id/shapeLine"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_line"
                app:tint="?attr/mainTextColor" />

            <ImageButton
                android:id="@+id/shapeRect"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_rect"
                app:tint="?attr/mainTextColor" />

            <ImageButton
                android:id="@+id/shapeCircle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_circle"
                app:tint="?attr/mainTextColor" />

            <ImageButton
                android:id="@+id/shapeTriangle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_triangle"
                app:tint="?attr/mainTextColor" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Symmetry Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/symmetryPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/cardBackgroundColor"
        app:cardCornerRadius="20dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="@id/sideTools"
        app:layout_constraintStart_toEndOf="@id/sideTools"
        app:layout_constraintTop_toTopOf="@id/sideTools">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/symNone"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_back"
                app:tint="?attr/mainTextColor" />

            <ImageButton
                android:id="@+id/symVertical"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_line"
                app:tint="?attr/mainTextColor" />

            <ImageButton
                android:id="@+id/symHorizontal"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_line"
                android:rotation="90"
                app:tint="?attr/mainTextColor" />

            <ImageButton
                android:id="@+id/symRadial"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/chip_selector"
                android:src="@drawable/ic_radial_symmetry"
                app:tint="?attr/mainTextColor" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Reference Panel -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/referencePanel"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/cardBackgroundColor"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/imgReference"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside" />

            <ImageButton
                android:id="@+id/btnCloseReference"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_margin="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_back"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?attr/mainTextColor" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Settings Panel -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/settingsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="?attr/cardBackgroundColor"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="Размер"
                        android:textColor="?attr/secondaryTextColor"
                        android:textSize="11sp" />

                    <SeekBar
                        android:id="@+id/sbSize"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="200"
                        android:progress="20" />

                    <TextView
                        android:id="@+id/tvSizeValue"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="20"
                        android:textColor="?attr/mainTextColor"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="Прозрачность"
                        android:textColor="?attr/secondaryTextColor"
                        android:textSize="11sp" />

                    <SeekBar
                        android:id="@+id/sbOpacity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="255"
                        android:progress="255" />

                    <TextView
                        android:id="@+id/tvOpacityValue"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="255"
                        android:textColor="?attr/mainTextColor"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:text="Жёсткость"
                        android:textColor="?attr/secondaryTextColor"
                        android:textSize="11sp" />

                    <SeekBar
                        android:id="@+id/sbHardness"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="100" />

                    <TextView
                        android:id="@+id/tvHardnessValue"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="100"
                        android:textColor="?attr/mainTextColor"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Palette and Color Preview -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="?attr/cardBackgroundColor"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="8dp">

                <View
                    android:id="@+id/currentColorPreview"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/photo_button_bg" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPalette"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btnColorPicker"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_eyedropper"
                    app:tint="?attr/mainTextColor" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Customize your light theme here. -->
        <item name="android:windowBackground">?attr/backgroundColor</item>
        <item name="colorSurface">?attr/backgroundColor</item>

        <item name="backgroundColor">@color/bg_light</item>
        <item name="cardBackgroundColor">@color/card_bg_light</item>
